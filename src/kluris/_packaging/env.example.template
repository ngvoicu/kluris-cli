# Documented copy of every supported env var. Copy to .env and fill
# in the values for whichever auth path you use.

# Auth path — set exactly one (API-key OR OAuth). Both = fail-fast at boot.

# === API-key path ====================================================
# Either Anthropic-style or OpenAI-style endpoint shape.
KLURIS_PROVIDER_SHAPE=anthropic
KLURIS_BASE_URL=https://api.anthropic.com
KLURIS_API_KEY=sk-replace-me
KLURIS_MODEL=claude-opus-4-7

# === OAuth client_credentials path ===================================
# Use this when fronting an internal company gateway with OAuth 2.0.
# KLURIS_OAUTH_TOKEN_URL=https://idp.example.com/token
# KLURIS_OAUTH_API_BASE_URL=https://gateway.example.com
# KLURIS_OAUTH_CLIENT_ID=kluris-app
# KLURIS_OAUTH_CLIENT_SECRET=oauth-secret-here
# KLURIS_OAUTH_SCOPE=read:llm  # optional

# === Optional tunables ================================================

# Anthropic API version header (Anthropic shape only).
KLURIS_ANTHROPIC_VERSION=2023-06-01

# Max iterations of the tool-calling loop per user turn.
MAX_AGENT_ROUNDS=8

# Byte budget for the lobe_overview tool's JSON-encoded payload.
# Clamped to [1024, 16384].
KLURIS_LOBE_OVERVIEW_BUDGET=4096

# Max paths per multi_read call. Clamped to [1, 20].
KLURIS_MAX_MULTI_READ_PATHS=5
