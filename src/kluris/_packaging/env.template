# Generated by `kluris pack`. Uncomment exactly one auth path
# (API key OR OAuth) and fill in the credentials. Then `docker
# compose up`.

# --- API-key path -----------------------------------------------------
# KLURIS_PROVIDER_SHAPE=anthropic            # anthropic | openai
# KLURIS_BASE_URL=https://api.anthropic.com  # any compatible endpoint
# KLURIS_API_KEY=sk-...                      # NEVER commit this
# KLURIS_MODEL=claude-opus-4-7

# --- OAuth client_credentials path ------------------------------------
# KLURIS_OAUTH_TOKEN_URL=https://idp.example.com/token
# KLURIS_OAUTH_API_BASE_URL=https://gateway.example.com
# KLURIS_OAUTH_CLIENT_ID=kluris-app
# KLURIS_OAUTH_CLIENT_SECRET=oauth-secret-here
# KLURIS_OAUTH_SCOPE=                        # optional
# KLURIS_MODEL=internal-model-v2

# --- Optional tunables (sane defaults — override only if needed) ------
# KLURIS_ANTHROPIC_VERSION=2023-06-01
# MAX_AGENT_ROUNDS=8
# KLURIS_LOBE_OVERVIEW_BUDGET=4096
# KLURIS_MAX_MULTI_READ_PATHS=5

# --- TLS for corporate / on-prem LLM gateways -------------------------
# Use exactly one (or neither). Defaults: system CA bundle, verification on.
#
# Path inside the container to a PEM bundle that includes your private
# root CA. Mount it as a volume in compose if it lives outside the image.
# KLURIS_CA_BUNDLE=/data/corp-root-ca.pem
#
# Disables TLS verification entirely. Opt-in only — prints a loud
# warning at boot. Prefer KLURIS_CA_BUNDLE wherever possible.
# KLURIS_TLS_INSECURE=1
